{
  "name": "expense-tracker-backend",
  "version": "1.0.1",
  "private": true,
  "description": "每日消费记录助手 - 后端服务（Vite + React + Express）",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n VITE,EXPRESS -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "mysql2": "^3.11.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6"
  }
}
