# ====== 数据库配置 ======
# 主机地址
DB_HOST=127.0.0.1
# 端口（你部署 MySQL 时用了 3307）
DB_PORT=3307
# 用户名
DB_USER=root
# 密码
DB_PASSWORD=root
# 数据库名（与 004 目录建库脚本保持一致）
DB_NAME=expense_tracker

# ====== JWT 鉴权 ======
# 用于签发和验证 token 的密钥（生产环境务必修改为长随机字符串）
JWT_SECRET=please_change_me_to_a_long_random_string_in_production
# token 有效期（秒），默认 7 天
JWT_EXPIRES_IN=604800